{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tchap",
  "version": "4.19.1",
  "identifier": "fr.gouv.beta.tchap-desktop-no-updater",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "windows": {
      "allowDowngrades": true,
      "nsis": {
        "installMode": "both"
      },
      "wix": {
        "language": "fr-FR",
        "template": null
      }
    },
    "createUpdaterArtifacts": false,
    "resources": {
      "resources/windows/msvcp140.dll": "./msvcp140.dll",
      "resources/windows/vcruntime140.dll": "./vcruntime140.dll"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "tchap"
        ]
      }
    },
    "protocol": {
      "schemas": [
        "tchap"
      ]
    }
  }
}
